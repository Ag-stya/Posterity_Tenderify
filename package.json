{
  "name": "tenderwatch-live",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "db:generate": "pnpm --filter @tenderwatch/db generate",
    "db:migrate": "pnpm --filter @tenderwatch/db migrate",
    "db:seed": "pnpm --filter @tenderwatch/db seed",
    "db:push": "pnpm --filter @tenderwatch/db push",
    "dev:api": "pnpm --filter @tenderwatch/api dev",
    "dev:worker": "pnpm --filter @tenderwatch/worker dev",
    "dev:web": "pnpm --filter @tenderwatch/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint"
  },
  "engines": {
    "node": ">=20"
  }
}
