# ──────────────────────────────────────
# TENDERWATCH-LIVE Environment Config
# ──────────────────────────────────────

# Postgres (with pgvector)
DATABASE_URL=postgresql://tenderwatch:tenderwatch@postgres:5432/tenderwatch?schema=public

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Admin seed (used by db:seed)
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=admin123
BD_EMAIL=bd@local
BD_PASSWORD=bd123

# Embedding model (Transformers.js)
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Crawl defaults
DEFAULT_CRAWL_INTERVAL_MINUTES=10
DEFAULT_RATE_LIMIT_PER_MINUTE=30
CRAWL_GLOBAL_CONCURRENCY=5

# API
API_PORT=4000
CORS_ORIGIN=http://tenderwatch.posterity.in

# Web
NEXT_PUBLIC_API_URL=http://168.144.29.209:4000
WEB_PORT=3000
